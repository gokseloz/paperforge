{
  "name": "paperforge",
  "version": "0.1.4",
  "description": "Compose PDFs from Handlebars templates, a JSON recipe, and your data. Recipe-driven composition with per-template theming.",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "paperforge": "src/cli.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node scripts/smoke-test.js",
    "example:invoice": "node src/cli.js --templates examples/invoice --data examples/invoice/data.json --out out/invoice.pdf",
    "example:report": "node src/cli.js --templates examples/report --data examples/report/data.json --out out/report.pdf",
    "example:resume": "node src/cli.js --templates examples/resume --data examples/resume/data.json --out out/resume.pdf"
  },
  "keywords": [
    "pdf",
    "handlebars",
    "puppeteer",
    "template",
    "document-generation",
    "report",
    "invoice"
  ],
  "author": "gxl",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gokseloz/paperforge.git"
  },
  "bugs": {
    "url": "https://github.com/gokseloz/paperforge/issues"
  },
  "homepage": "https://github.com/gokseloz/paperforge#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "date-fns": "^4.1.0",
    "handlebars": "^4.7.8",
    "puppeteer": "^23.0.0"
  }
}
