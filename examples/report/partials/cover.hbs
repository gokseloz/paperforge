<section class="page" style="background: linear-gradient(135deg, {{theme.primaryColor}} 0%, {{theme.accentColor}} 100%); color: white; display: flex; flex-direction: column; justify-content: space-between; min-height: 90vh;">
  <div>
    <div style="font-size: 10pt; letter-spacing: 3px; text-transform: uppercase; opacity: 0.8;">
      {{report.client}} · {{report.period}}
    </div>
    <h1 style="color: white; font-size: 44pt; margin-top: 24px; line-height: 1.1;">
      {{report.title}}
    </h1>
    <p style="font-size: 14pt; opacity: 0.9; max-width: 540px; margin-top: 16px;">
      {{report.subtitle}}
    </p>
  </div>
  <div style="font-size: 10pt; opacity: 0.7;">
    Prepared by {{report.author}} · {{formatDate report.preparedAt "MMMM d, yyyy"}}
  </div>
</section>
